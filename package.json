{
	"name": "xvlog-linter",
	"displayName": "xvlog Linter",
	"description": "Verilog and SystemVerilog linting using Xilinx xvlog (Vivado)",
	"version": "0.0.1",
	"publisher": "your-publisher-id",
	"icon": "images/icon.png",
	"engines": {
		"vscode": "^1.93.1"
	},
	"categories": [
		"Linters",
		"Programming Languages"
	],
	"keywords": [
		"verilog",
		"systemverilog",
		"xvlog",
		"xilinx",
		"vivado",
		"fpga",
		"linter"
	],
	"activationEvents": [
		"onLanguage:verilog",
		"onLanguage:systemverilog"
	],
	"main": "./dist/extension.js",
	"contributes": {
		"commands": [
			{
				"command": "xvlog-linter.lint",
				"title": "xvlog: Lint Current File",
				"category": "Verilog"
			},
			{
				"command": "xvlog-linter.clearDiagnostics",
				"title": "xvlog: Clear Diagnostics",
				"category": "Verilog"
			}
		],
		"configuration": {
			"title": "xvlog Linter",
			"properties": {
				"xvlog.path": {
					"type": "string",
					"default": "",
					"description": "Path to the directory containing the xvlog binary. Leave empty if xvlog is already on your PATH.",
					"scope": "resource"
				},
				"xvlog.linting.enabled": {
					"type": "boolean",
					"default": true,
					"description": "Enable or disable the xvlog linter.",
					"scope": "resource"
				},
				"xvlog.linting.arguments": {
					"type": "string",
					"default": "",
					"description": "Additional command-line arguments passed to xvlog.",
					"scope": "resource"
				},
				"xvlog.linting.includePath": {
					"type": "array",
					"items": {
						"type": "string"
					},
					"default": [],
					"description": "Include paths for xvlog. Relative paths resolve from the workspace root.",
					"scope": "resource"
				},
				"xvlog.linting.runAtFileLocation": {
					"type": "boolean",
					"default": false,
					"description": "Run xvlog in the directory of the file being linted instead of the workspace root.",
					"scope": "resource"
				}
			}
		}
	},
	"scripts": {
		"vscode:prepublish": "npm run package",
		"compile": "npm run check-types && npm run lint && node esbuild.js",
		"watch": "npm-run-all -p watch:*",
		"watch:esbuild": "node esbuild.js --watch",
		"watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
		"package": "npm run check-types && npm run lint && node esbuild.js --production",
		"compile-tests": "tsc -p . --outDir out",
		"watch-tests": "tsc -p . -w --outDir out",
		"pretest": "npm run compile-tests && npm run compile && npm run lint",
		"check-types": "tsc --noEmit",
		"lint": "eslint src",
		"test": "vscode-test"
	},
	"devDependencies": {
		"@types/vscode": "^1.93.1",
		"@types/mocha": "^10.0.10",
		"@types/node": "22.x",
		"@types/sinon": "^17.0.0",
		"sinon": "^18.0.0",
		"typescript-eslint": "^8.56.1",
		"eslint": "^9.39.3",
		"esbuild": "^0.27.3",
		"npm-run-all": "^4.1.5",
		"typescript": "^5.9.3",
		"@vscode/test-cli": "^0.0.12",
		"@vscode/test-electron": "^2.5.2"
	},
	"repository": {
		"url": "https://github.com/laperex/xvlog-linter"
	}
}